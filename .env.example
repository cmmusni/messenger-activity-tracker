PORT=3000
NODE_ENV=development
VERIFY_TOKEN=replace_with_your_custom_verify_token
PAGE_ACCESS_TOKEN=replace_with_your_page_access_token
APP_SECRET=replace_with_your_meta_app_secret
GRAPH_API_VERSION=v21.0
ENABLE_AUTO_REPLY=true
ADMIN_API_KEY=replace_with_admin_key

# Postgres connection string. Examples:
#   postgres://user:pass@localhost:5432/activity_tracker
#   postgres://user:pass@host/dbname?sslmode=require   (managed Postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/activity_tracker
# Force TLS for managed providers (Neon, Supabase, Vercel Postgres, RDS, etc.)
PGSSL=false

CORS_ORIGIN=*
